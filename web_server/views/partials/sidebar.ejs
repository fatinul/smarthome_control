<style>
  .hamburger {
    position: fixed;
    top: 12px;
    left: 12px;
    z-index: 1001;
    background: #2a2a2a;
    border: 1px solid #444;
    color: #fff;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    transition: background .15s;
  }
  .hamburger:hover { background: #3a3a3a; }
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 220px;
    height: 100vh;
    background: #1a1a1a;
    border-right: 1px solid #333;
    z-index: 1000;
    transform: translateX(-100%);
    transition: transform .25s ease;
    padding: 64px 0 0 0;
  }
  .sidebar.open { transform: translateX(0); }
  .sidebar a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    color: #aaa;
    text-decoration: none;
    font-size: 14px;
    transition: background .15s;
  }
  .sidebar a:hover { background: #2a2a2a; color: #fff; }
  .sidebar a.active { color: #60a5fa; border-left: 3px solid #60a5fa; background: #1a2740; }
  .sidebar a svg { width: 20px; height: 20px; flex-shrink: 0; }
  .sidebar-backdrop {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,.5);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease;
  }
  .sidebar-backdrop.show { opacity: 1; pointer-events: auto; }
</style>

<button class="hamburger" id="hamburger" aria-label="Menu">☰</button>
<div class="sidebar-backdrop" id="sidebar-backdrop"></div>
<div class="sidebar" id="sidebar">
  <a href="/">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
    </svg>
    Home
  </a>
  <a href="/map">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
    </svg>
    Map
  </a>
  <a href="/map-v2">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 4v16m8-8H4"/>
      <circle cx="12" cy="12" r="10"/>
    </svg>
    Map V2
  </a>
</div>

<script>
  (function() {
    const hamburger = document.getElementById('hamburger');
    const sidebar = document.getElementById('sidebar');
    const sidebarBackdrop = document.getElementById('sidebar-backdrop');

    function toggleSidebar() {
      sidebar.classList.toggle('open');
      sidebarBackdrop.classList.toggle('show');
    }

    hamburger.addEventListener('click', toggleSidebar);
    sidebarBackdrop.addEventListener('click', toggleSidebar);

    const path = window.location.pathname;
    document.querySelectorAll('.sidebar a').forEach(function(a) {
      if (a.getAttribute('href') === path) a.classList.add('active');
    });
  })();
</script>
