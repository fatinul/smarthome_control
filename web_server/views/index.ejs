<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>CCTV Camera Feeds</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #0f0f0f;
      color: #fff;
      padding: 24px;
    }
    h1 { text-align: center; margin-bottom: 8px; font-weight: 600; }
    .subtitle { text-align: center; color: #888; margin-bottom: 28px; font-size: 14px; }
    .error {
      background: #3b1a1a;
      border: 1px solid #9b2c2c;
      color: #fca5a5;
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      text-align: center;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 12px;
    }
    .card {
      background: #1a1a1a;
      border-radius: 10px;
      cursor: pointer;
      transition: box-shadow .2s, transform .2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 24px 16px;
    }
    .card:hover {
      box-shadow: 0 6px 24px rgba(96, 165, 250, 0.2);
      transform: translateY(-2px);
    }
    .card svg {
      width: 40px;
      height: 40px;
      opacity: .6;
    }
    .card span {
      font-size: 12px;
      font-weight: 500;
      color: #aaa;
    }

    #preview {
      display: none;
      position: fixed;
      z-index: 999;
      width: 400px;
      background: #000;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.8);
      pointer-events: none;
    }
    #preview.show {
      display: block;
    }
    #preview .ratio {
      position: relative;
      width: 100%;
      padding-top: 56.25%;
    }
    #preview iframe {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      border: 0;
    }
    #preview .label {
      position: absolute;
      top: 0; left: 0;
      padding: 6px 10px;
      font-size: 11px;
      font-weight: 600;
      background: rgba(0,0,0,.7);
      color: #fff;
      z-index: 1;
    }
  </style>
</head>
<body>
  <h1>CCTV Camera Feeds</h1>
  <p class="subtitle">Hover a camera to preview</p>

  <% if (typeof error !== 'undefined') { %>
    <div class="error"><%= error %></div>
  <% } %>

  <div class="grid">
    <% streams.forEach(stream => { %>
    <div class="card" data-stream="<%= stream %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M23 7l-7 5 7 5V7z"/>
        <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
      </svg>
      <span><%= stream %></span>
    </div>
    <% }) %>
  </div>

  <div id="preview">
    <div class="ratio">
      <div class="label"></div>
      <iframe allow="autoplay"></iframe>
    </div>
  </div>

  <% if (streams.length === 0 && typeof error === 'undefined') { %>
    <p style="text-align:center;color:#888;margin-top:60px">No streams found.</p>
  <% } %>

  <script>
    const preview = document.getElementById('preview');
    const previewIframe = preview.querySelector('iframe');
    const previewLabel = preview.querySelector('.label');
    let currentStream = '';
    let timer;

    // Pre-connect to the first stream so it's always loaded
    const firstCard = document.querySelector('.card');
    if (firstCard) {
      currentStream = firstCard.dataset.stream;
      previewIframe.src = 'http://localhost:1984/stream.html?src=' + currentStream + '&mode=mse';
    }

    document.querySelectorAll('.card').forEach(card => {
      const stream = card.dataset.stream;

      card.addEventListener('mouseenter', (e) => {
        clearTimeout(timer);
        previewLabel.textContent = stream;
        if (stream !== currentStream) {
          currentStream = stream;
          previewIframe.src = 'http://localhost:1984/stream.html?src=' + stream + '&mode=mse';
        }
        positionPreview(e.clientX, e.clientY);
        preview.classList.add('show');
      });

      card.addEventListener('mousemove', (e) => {
        if (stream === currentStream) {
          positionPreview(e.clientX, e.clientY);
        }
      });

      card.addEventListener('mouseleave', () => {
        timer = setTimeout(() => {
          preview.classList.remove('show');
        }, 200);
      });
    });

    function positionPreview(cx, cy) {
      const w = 400, h = 225;
      let x = cx + 16;
      let y = cy + 16;

      const maxX = window.innerWidth - w - 16;
      const maxY = window.innerHeight - h - 16;

      if (x > maxX) x = cx - w - 16;
      if (y > maxY) y = cy - h - 16;
      if (x < 16) x = 16;
      if (y < 16) y = 16;

      preview.style.left = x + 'px';
      preview.style.top = y + 'px';
    }
  </script>
</body>
</html>
