<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>CCTV Camera Feeds</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #0f0f0f;
      color: #fff;
      padding: 24px;
    }
    h1 { text-align: center; margin-bottom: 8px; font-weight: 600; }
    .subtitle { text-align: center; color: #888; margin-bottom: 28px; font-size: 14px; }
    .error {
      background: #3b1a1a;
      border: 1px solid #9b2c2c;
      color: #fca5a5;
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      text-align: center;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
      gap: 20px;
    }
    .card {
      background: #1a1a1a;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    }
    .card-header {
      padding: 10px 16px;
      font-weight: 600;
      font-size: 14px;
      background: #242424;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .card-header a {
      color: #60a5fa;
      text-decoration: none;
      font-size: 12px;
      font-weight: 400;
    }
    .card-header a:hover { text-decoration: underline; }
    .card-body {
      position: relative;
      width: 100%;
      padding-top: 56.25%;
      background: #000;
    }
    .card-body iframe, .card-body img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  </style>
</head>
<body>
  <h1>CCTV Camera Feeds</h1>
  <p class="subtitle">Live camera feeds</p>

  <% if (typeof error !== 'undefined') { %>
    <div class="error"><%= error %></div>
  <% } %>

  <div class="grid">
    <% streams.forEach(stream => { %>
    <div class="card">
      <div class="card-header">
        <span><%= stream %></span>
        <a href="http://localhost:1984/#<%= stream %>" target="_blank">Live &rarr;</a>
      </div>
      <div class="card-body">
        <iframe src="http://localhost:1984/stream.html?src=<%= stream %>&mode=mse"
                allow="autoplay" loading="lazy"
                onerror="this.parentElement.innerHTML='<div style=\'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#666;font-size:14px\'>No signal</div>'"></iframe>
      </div>
    </div>
    <% }) %>
  </div>

  <% if (streams.length === 0 && typeof error === 'undefined') { %>
    <p style="text-align:center;color:#888;margin-top:60px">No streams found.</p>
  <% } %>


</body>
</html>
