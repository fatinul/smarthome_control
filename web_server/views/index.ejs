<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>CCTV Camera TINUL</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #0f0f0f;
      color: #fff;
      padding: 24px;
    }
    h1 { text-align: center; margin-bottom: 8px; font-weight: 600; }
    .subtitle { text-align: center; color: #888; margin-bottom: 28px; font-size: 14px; }
    .error {
      background: #3b1a1a;
      border: 1px solid #9b2c2c;
      color: #fca5a5;
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      text-align: center;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 12px;
    }
    .card {
      background: #1a1a1a;
      border-radius: 10px;
      cursor: pointer;
      transition: box-shadow .2s, transform .2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 24px 16px;
    }
    .card:hover {
      box-shadow: 0 6px 24px rgba(96, 165, 250, 0.2);
      transform: translateY(-2px);
    }
    .card svg {
      width: 40px;
      height: 40px;
      opacity: .6;
    }
    .card span {
      font-size: 12px;
      font-weight: 500;
      color: #aaa;
    }

    #preview {
      display: none;
      position: fixed;
      z-index: 999;
      width: 400px;
      background: #000;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.8);
      pointer-events: none;
    }
    #preview.show {
      display: block;
    }
    #preview .ratio {
      position: relative;
      width: 100%;
      padding-top: 56.25%;
    }
    #preview iframe {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      border: 0;
    }
    #preview .label {
      position: absolute;
      top: 0; left: 0;
      padding: 6px 10px;
      font-size: 11px;
      font-weight: 600;
      background: rgba(0,0,0,.7);
      color: #fff;
      z-index: 1;
    }

    /* Sidebar */
    .hamburger {
      position: fixed;
      top: 12px;
      left: 12px;
      z-index: 1001;
      background: #2a2a2a;
      border: 1px solid #444;
      color: #fff;
      width: 36px;
      height: 36px;
      border-radius: 6px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      transition: background .15s;
    }
    .hamburger:hover { background: #3a3a3a; }
    .sidebar {
      position: fixed;
      top: 0; left: 0;
      width: 220px;
      height: 100vh;
      background: #1a1a1a;
      border-right: 1px solid #333;
      z-index: 1000;
      transform: translateX(-100%);
      transition: transform .25s ease;
      padding: 64px 0 0 0;
    }
    .sidebar.open { transform: translateX(0); }
    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 20px;
      color: #aaa;
      text-decoration: none;
      font-size: 14px;
      transition: background .15s;
    }
    .sidebar a:hover { background: #2a2a2a; color: #fff; }
    .sidebar a.active { color: #60a5fa; border-left: 3px solid #60a5fa; background: #1a2740; }
    .sidebar a svg { width: 20px; height: 20px; flex-shrink: 0; }
    .sidebar-backdrop {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,.5);
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s ease;
    }
    .sidebar-backdrop.show { opacity: 1; pointer-events: auto; }
  </style>
</head>
<body>
  <button class="hamburger" id="hamburger" aria-label="Menu">☰</button>
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>
  <div class="sidebar" id="sidebar">
    <a href="/">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Home
    </a>
    <a href="/map">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
      </svg>
      Map
    </a>
  </div>
  <h1>CCTV Camera Feeds</h1>
  <p class="subtitle">Hover a camera to test</p>

  <% if (typeof error !== 'undefined') { %>
    <div class="error"><%= error %></div>
  <% } %>

  <div class="grid">
    <% streams.forEach(stream => { %>
    <div class="card" data-stream="<%= stream %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M23 7l-7 5 7 5V7z"/>
        <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
      </svg>
      <span><%= stream %></span>
    </div>
    <% }) %>
  </div>

  <div id="preview">
    <div class="ratio">
      <div class="label"></div>
      <iframe allow="autoplay"></iframe>
    </div>
  </div>

  <% if (streams.length === 0 && typeof error === 'undefined') { %>
    <p style="text-align:center;color:#888;margin-top:60px">No streams found.</p>
  <% } %>

  <script>
    // Sidebar navigation
    const hamburger = document.getElementById('hamburger');
    const sidebar = document.getElementById('sidebar');
    const sidebarBackdrop = document.getElementById('sidebar-backdrop');

    function toggleSidebar() {
      sidebar.classList.toggle('open');
      sidebarBackdrop.classList.toggle('show');
    }

    hamburger.addEventListener('click', toggleSidebar);
    sidebarBackdrop.addEventListener('click', toggleSidebar);

    // Highlight current page
    const path = window.location.pathname;
    document.querySelectorAll('.sidebar a').forEach(a => {
      if (a.getAttribute('href') === path) a.classList.add('active');
    });

    const preview = document.getElementById('preview');
    const previewIframe = preview.querySelector('iframe');
    const previewLabel = preview.querySelector('.label');
    let currentStream = '';
    let timer;

    // Pre-connect to the first stream so it's always loaded
    const firstCard = document.querySelector('.card');
    if (firstCard) {
      currentStream = firstCard.dataset.stream;
      previewIframe.src = 'http://localhost:1984/stream.html?src=' + currentStream + '&mode=mse';
    }

    document.querySelectorAll('.card').forEach(card => {
      const stream = card.dataset.stream;

      card.addEventListener('mouseenter', (e) => {
        clearTimeout(timer);
        previewLabel.textContent = stream;
        if (stream !== currentStream) {
          currentStream = stream;
          previewIframe.src = 'http://localhost:1984/stream.html?src=' + stream + '&mode=mse';
        }
        positionPreview(e.clientX, e.clientY);
        preview.classList.add('show');
      });

      card.addEventListener('mousemove', (e) => {
        if (stream === currentStream) {
          positionPreview(e.clientX, e.clientY);
        }
      });

      card.addEventListener('mouseleave', () => {
        timer = setTimeout(() => {
          preview.classList.remove('show');
        }, 200);
      });
    });

    function positionPreview(cx, cy) {
      const w = 400, h = 225;
      let x = cx + 16;
      let y = cy + 16;

      const maxX = window.innerWidth - w - 16;
      const maxY = window.innerHeight - h - 16;

      if (x > maxX) x = cx - w - 16;
      if (y > maxY) y = cy - h - 16;
      if (x < 16) x = 16;
      if (y < 16) y = 16;

      preview.style.left = x + 'px';
      preview.style.top = y + 'px';
    }
  </script>
</body>
</html>
